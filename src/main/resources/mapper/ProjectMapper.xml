<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auto.test.platform.mapper.ProjectMapper">
    <!-- 后续复杂SQL写在这里，如多表联查、统计查询 -->
    <select id="selectProjectByName" resultType="com.auto.test.platform.entity.Project">
        SELECT * FROM project WHERE project_name = #{projectName} AND status = 1
    </select>
</mapper>